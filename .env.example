# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================
DB_HOST=postgres
DB_PORT=5432
DB_USER=change_me
DB_PASS=generate_a_strong_password
DB_NAME=vivero_online

# ============================================================================
# JWT CONFIGURATION
# ============================================================================
JWT_SECRET=generate_a_long_random_secret
JWT_EXPIRATION=7200

# ============================================================================
# APPLICATION
# ============================================================================
NODE_ENV=development
PORT=3000
FRONTEND_URL=http://localhost

# ============================================================================
# LOGGING & DEBUG
# ============================================================================
LOG_LEVEL=debug

# ============================================================================
# CACHE (Redis) - OPCIONAL
# ============================================================================
REDIS_HOST=redis
REDIS_PORT=6379
ENABLE_CACHE=false

# ============================================================================
# ERROR TRACKING (Sentry) - OPCIONAL
# ============================================================================
SENTRY_DSN=
SENTRY_ENVIRONMENT=development

# ============================================================================
# API VERSIONING
# ============================================================================
# Usar: /api/v1/... o /api/v2/...
# Cambiar en .env para usar versión diferente
API_VERSION=v1
